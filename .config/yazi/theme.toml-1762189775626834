# : Manager [[[

[manager]
cwd = { fg = "#dfe3e8" }

# Tab
tab_active = { fg = "#00344d", bg = "#94cdf6", bold = true }
tab_inactive = { fg = "#c8e6ff", bg = "#001e2e" }
tab_width = 1

# Find
find_keyword = { fg = "#ffb4ab", bold = true, italic = true, underline = true }
find_position = { fg = "#ffb4ab", bold = true, italic = true }

# Marker
marker_copied = { fg = "#a777ff", bg = "#a777ff" }
marker_cut = { fg = "#e9ddff", bg = "#e9ddff" }
marker_marked = { fg = "#ffb4ab", bg = "#ffb4ab" }
marker_selected = { fg = "#cec0e8", bg = "#cec0e8" }

# Count
count_copied = { fg = "#1f1635", bg = "#e9ddff" }
count_cut = { fg = "#1f1635", bg = "#e9ddff" }
count_selected = { fg = "#00344d", bg = "#cec0e8" }

# Border
border_symbol = "│"
border_style  = { fg = "#94cdf6" }

# : ]]]


# : Status [[[

[status]
separator_open = "🭁"
separator_close = "🭠"
separator_style = { bg = "#00344d", fg = "#F4A261" }

[mode]
# Mode
normal_main = { bg = "#94cdf6", fg = "#00344d", bold = true }
normal_alt  = { bg = "#41484d", fg = "#c1c7ce" }

# Select mode
select_main = { bg = "#b7c9d8", fg = "#21323f", bold = true }
select_alt  = { bg = "#41484d", fg = "#c1c7ce" }

# Unset mode
unset_main = { bg = "#cec0e8", fg = "#342b4b", bold = true }
unset_alt  = { bg = "#41484d", fg = "#c1c7ce" }

# Progress
progress_label = { bold = true }
progress_normal = { fg = "#94cdf6", bg = "#353a3e" }
progress_error = { fg = "#ffb4ab", bg = "#353a3e" }

# Permissions
permissions_t = { fg = "#567ea0" }
permissions_w = { fg = "#7750bf" }
permissions_x = { fg = "#ff2b12" }
permissions_r = { fg = "#8644ff" }
permissions_s = { fg = "#2fa0ff" }

# : ]]]


# : Select [[[

[select]
border = { fg = "#94cdf6" }
active = { fg = "#cec0e8", bold = true }
inactive = {}

# : ]]]


# : Input [[[

[input]
border = { fg = "#94cdf6" }
value = { fg = "#dfe3e8" }

# : ]]]


# : Completion [[[

[completion]
border = { fg = "#94cdf6", bg = "#00344d" }

# : ]]]


# : Tasks [[[

[tasks]
border = { fg = "#94cdf6" }
title = {}
hovered = { fg = "#e9ddff", underline = true }

# : ]]]


# : Which [[[

[which]
cols = 3
mask = { bg = "#353a3e" }
cand = { fg = "#94cdf6" }
rest = { fg = "#00344d" }
desc = { fg = "#dfe3e8" }
separator = " ▶ "
separator_style = { fg = "#dfe3e8" }

# : ]]]


# : Help [[[

[help]
on = { fg = "#dfe3e8" }
run = { fg = "#dfe3e8" }
footer = { fg = "#21323f", bg = "#b7c9d8" }

# : ]]]


# : Notify [[[

[notify]
title_info = { fg = "#cec0e8" }
title_warn = { fg = "#94cdf6" }
title_error = { fg = "#ffb4ab" }

# : ]]]


# : File-specific styles [[[

[filetype]

rules = [
    # Images
    { mime = "image/*", fg = "#94e2d5" },

    # Media
    { mime = "{audio,video}/*", fg = "#f9e2af" },

    # Archives
    { mime = "application/{zip,rar,7z*,tar,gzip,xz,zstd,bzip*,lzma,compress,archive,cpio,arj,xar,ms-cab*}", fg = "#f5c2e7" },

    # Documents
    { mime = "application/{pdf,doc,rtf}", fg = "#a6e3a1" },

    # Special files
    { name = "*", is = "orphan", bg = "#93000a" },
    { name = "*", is = "exec", fg = "#ffdad6" },

    # Fallback
    { name = "*", fg = "#dfe3e8" },
    { name = "*/", fg = "#94cdf6" },
]

# : ]]]

